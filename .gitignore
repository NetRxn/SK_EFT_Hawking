# dev-harness runtime state (markers, watermarks, caches, locks)
/.claude/dev-harness/

# parallel-agent worktree slots (wt1/wt2/wt3) — created by `claude --worktree wtN`
# / EnterWorktree; served by lean-lsp-wt1/2/3 in the workspace .mcp.json.
# Keep them out of the main checkout's status so a worktree's files never
# appear as untracked here (and never reach the leak pre-commit scan).
/.claude/worktrees/
docs/dev-loops/SYSTEM2_REGISTER.md
docs/dev-loops/SYSTEM2_ARCHIVE.md
# transient resume/handoff working-docs (write one, resume from it, delete it when the objective
# lands) — never tracked; mingling them with the curated dev-loop docs is noise
docs/dev-loops/*HANDOFF*.md
# lab notebooks (live brick-log state, AUTO-WRITTEN in full-/goal mode → NEVER committed, so
# they cannot leak private content into public git). In-repo default home (docs/dev-loops/<roadmap>/)
# gives stable paths + lets the pre-commit `notebook check` run, but the files themselves stay
# git-ignored; the tracked durable artifact is the small, reviewable goal_prompt_<goal_id>.md.
**/LAB_NOTEBOOK*.md
# auto-generated timestamped validation reports (validate.py / gate_precheck.py write one EVERY
# run → ~2200 files of noise + repo bloat; originally had archival value, now unhelpful). Generated
# locally on demand; never tracked. The CURATED review docs in docs/validation/ (VALIDATION_REPORT.md,
# the phase6x stage-13 reviews, audits) are NOT under reports/ and stay tracked.
docs/validation/reports/

# Web-egress denylist — operator-installed LOCAL copy (untracked; may hold private
# literals incl. firewall terms). Committed template = research_egress_denylist.sample.txt.
# Match the basename anywhere (never the .sample.txt template).
research_egress_denylist.txt

# ExtractDeps incremental build caches (ADR-005 D-G.2). Machine-local, regenerated on demand,
# pin-/declHash-keyed; never tracked (they only change extraction wall-time, never results).
lean/.lean_immref_cache.json
lean/.lean_mathlib_closure_cache.json
lean/.lean_typestr_cache.json
lean/.lean_json_cache.json
