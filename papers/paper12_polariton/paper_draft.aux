\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Stimulated Hawking gain $G(\omega )$ vs.\ normalized frequency $\omega /\kappa $. The dashed line marks $G = 0.01$, below which $>10^4$ probe photons per mode are needed for $5\sigma $ detection. The shaded region is the optimal probe window.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:gain}{{1}{2}{Stimulated Hawking gain $G(\omega )$ vs.\ normalized frequency $\omega /\kappa $. The dashed line marks $G = 0.01$, below which $>10^4$ probe photons per mode are needed for $5\sigma $ detection. The shaded region is the optimal probe window}{figure.1}{}}
