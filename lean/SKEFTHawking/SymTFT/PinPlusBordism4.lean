import Mathlib
import SKEFTHawking.SymTFT.PinPlusManifold4

namespace SKEFTHawking.SymTFT

/-! ## ¬ß1. Pin‚Å∫ bordism Setoid via signature mod 16 -/

/-- **`PinPlusBordism4Setoid`** ‚Äî the bordism Setoid on `PinPlusManifold4`.

Two Pin‚Å∫ 4-manifolds M, N are equivalent in the substrate iff their
signatures differ by a multiple of 16:
`M ~ N ‚Üî 16 ‚à£ (M.signature - N.signature)`.

Per Rokhlin's theorem (1952) lifted via the Spin double cover, this is
the canonical Z16-content of Pin‚Å∫ bordism. Two manifolds bordant in
the full Pin‚Å∫ bordism sense have equal signature mod 16 (per
Kirby-Taylor 1990 ¬ß1), so this Setoid is SOUND with respect to the
target Œ©_4^{Pin‚Å∫}(pt) ‚âÖ ZMod 16 statement. -/
def PinPlusBordism4Setoid : Setoid PinPlusManifold4 where
  r M N := (16 : ‚Ñ§) ‚à£ (M.signature - N.signature)
  iseqv :=
    { refl := fun M => by show (16 : ‚Ñ§) ‚à£ (M.signature - M.signature); simp
      symm := fun {M N} h => by
        show (16 : ‚Ñ§) ‚à£ (N.signature - M.signature)
        have : N.signature - M.signature = -(M.signature - N.signature) := by ring
        rw [this]
        exact h.neg_right
      trans := fun {M N P} h‚ÇÅ h‚ÇÇ => by
        show (16 : ‚Ñ§) ‚à£ (M.signature - P.signature)
        have : M.signature - P.signature =
            (M.signature - N.signature) + (N.signature - P.signature) := by ring
        rw [this]
        exact dvd_add h‚ÇÅ h‚ÇÇ }

/-! ## ¬ß2. The Omega4PinPlusBordism quotient type -/

/-- **`Omega4PinPlusBordism`** ‚Äî the substantive Pin‚Å∫ bordism quotient.
Per Kirby-Taylor 1990, Œ©_4^{Pin‚Å∫}(pt) ‚âÖ ZMod 16; the substrate-level
type defined here captures that Z16 content via the
signature-mod-16 quotient. -/
def Omega4PinPlusBordism : Type := Quotient PinPlusBordism4Setoid

namespace Omega4PinPlusBordism

/-- The canonical projection `PinPlusManifold4 ‚Üí Omega4PinPlusBordism`. -/
def mk (M : PinPlusManifold4) : Omega4PinPlusBordism := Quotient.mk _ M

/-- The signature class is well-defined on `Omega4PinPlusBordism`,
landing in `ZMod 16`. -/
def signatureMod16 : Omega4PinPlusBordism ‚Üí ZMod 16 :=
  Quotient.lift (fun M => (M.signature : ZMod 16)) (fun M N h => by
    have hdvd : (16 : ‚Ñ§) ‚à£ (M.signature - N.signature) := h
    have hcast : ((M.signature - N.signature : ‚Ñ§) : ZMod 16) = 0 := by
      rw [ZMod.intCast_zmod_eq_zero_iff_dvd]; exact_mod_cast hdvd
    have hsub : (M.signature : ZMod 16) - (N.signature : ZMod 16) = 0 := by
      push_cast at hcast; exact hcast
    exact sub_eq_zero.mp hsub)

@[simp] theorem signatureMod16_mk (M : PinPlusManifold4) :
    signatureMod16 (mk M) = (M.signature : ZMod 16) := rfl

end Omega4PinPlusBordism

/-! ## ¬ß3. AddCommGroup instance on Omega4PinPlusBordism -/

open Omega4PinPlusBordism

instance : Zero Omega4PinPlusBordism := ‚ü®mk 0‚ü©

instance : Add Omega4PinPlusBordism :=
  ‚ü®Quotient.lift‚ÇÇ (fun M N => mk (M + N)) (fun M‚ÇÅ N‚ÇÅ M‚ÇÇ N‚ÇÇ h‚ÇÅ h‚ÇÇ => by
    apply Quotient.sound
    show (16 : ‚Ñ§) ‚à£ ((M‚ÇÅ + N‚ÇÅ).signature - (M‚ÇÇ + N‚ÇÇ).signature)
    have : (M‚ÇÅ + N‚ÇÅ).signature - (M‚ÇÇ + N‚ÇÇ).signature =
        (M‚ÇÅ.signature - M‚ÇÇ.signature) + (N‚ÇÅ.signature - N‚ÇÇ.signature) := by
      simp [PinPlusManifold4.add_signature]; ring
    rw [this]
    exact dvd_add h‚ÇÅ h‚ÇÇ)‚ü©

instance : Neg Omega4PinPlusBordism :=
  ‚ü®Quotient.lift (fun M => mk (-M)) (fun M N h => by
    apply Quotient.sound
    show (16 : ‚Ñ§) ‚à£ ((-M).signature - (-N).signature)
    have : (-M).signature - (-N).signature = -(M.signature - N.signature) := by
      simp; ring
    rw [this]
    exact h.neg_right)‚ü©

@[simp] theorem add_mk (M N : PinPlusManifold4) :
    (mk M : Omega4PinPlusBordism) + mk N = mk (M + N) := rfl

@[simp] theorem neg_mk (M : PinPlusManifold4) :
    -(mk M : Omega4PinPlusBordism) = mk (-M) := rfl

@[simp] theorem zero_eq_mk_zero :
    (0 : Omega4PinPlusBordism) = mk 0 := rfl

/-- The Quotient is an additive commutative group via signature additivity
respecting the bordism Setoid. -/
instance : AddCommGroup Omega4PinPlusBordism where
  add_assoc x y z := by
    induction x using Quotient.inductionOn with | _ M =>
    induction y using Quotient.inductionOn with | _ N =>
    induction z using Quotient.inductionOn with | _ P =>
    show mk (M + N + P) = mk (M + (N + P))
    congr 1; ext; simp [add_assoc]
  zero_add x := by
    induction x using Quotient.inductionOn with | _ M =>
    show mk (0 + M) = mk M
    congr 1; ext; simp
  add_zero x := by
    induction x using Quotient.inductionOn with | _ M =>
    show mk (M + 0) = mk M
    congr 1; ext; simp
  add_comm x y := by
    induction x using Quotient.inductionOn with | _ M =>
    induction y using Quotient.inductionOn with | _ N =>
    show mk (M + N) = mk (N + M)
    congr 1; ext; simp [add_comm]
  neg_add_cancel x := by
    induction x using Quotient.inductionOn with | _ M =>
    show mk (-M + M) = mk 0
    congr 1; ext; simp
  nsmul := nsmulRec
  zsmul := zsmulRec

/-! ## ¬ß4. Substantive iso `Omega4PinPlusBordism ‚âÉ+ ZMod 16` -/

/-- **`omega4PinPlusBordismToZMod16`** ‚Äî substantive AddMonoidHom from
the bordism quotient to ZMod 16, sending [M] to M.signature mod 16. -/
def omega4PinPlusBordismToZMod16 : Omega4PinPlusBordism ‚Üí+ ZMod 16 where
  toFun := signatureMod16
  map_zero' := by show signatureMod16 (mk 0) = 0; simp
  map_add' x y := by
    induction x using Quotient.inductionOn with | _ M =>
    induction y using Quotient.inductionOn with | _ N =>
    show signatureMod16 (mk (M + N)) = signatureMod16 (mk M) + signatureMod16 (mk N)
    show ((M + N).signature : ZMod 16) = (M.signature : ZMod 16) + (N.signature : ZMod 16)
    rw [PinPlusManifold4.add_signature]
    push_cast
    ring

@[simp] theorem omega4PinPlusBordismToZMod16_mk (M : PinPlusManifold4) :
    omega4PinPlusBordismToZMod16 (mk M) = (M.signature : ZMod 16) := rfl

/-- **`omega4PinPlusBordismOfZMod16`** ‚Äî the inverse map: send n ‚àà ZMod 16
to the class of the manifold with signature n. -/
def omega4PinPlusBordismOfZMod16 (n : ZMod 16) : Omega4PinPlusBordism :=
  mk ‚ü®n.val‚ü©

@[simp] theorem omega4PinPlusBordismOfZMod16_signature (n : ZMod 16) :
    signatureMod16 (omega4PinPlusBordismOfZMod16 n) = n := by
  show ((‚ü®n.val‚ü© : PinPlusManifold4).signature : ZMod 16) = n
  show ((n.val : ‚Ñ§) : ZMod 16) = n
  push_cast
  rw [ZMod.natCast_val, ZMod.cast_id]

/-- **`omega4PinPlusBordismEquivZMod16`** ‚Äî the substantive Kirby-Taylor
1990 isomorphism `Œ©_4^{Pin‚Å∫}(pt) ‚âÖ ZMod 16` at the substrate level.

This is the W1.2 culminating headline: the substantive Z16 content of
Pin‚Å∫ bordism is now witnessed by an explicit AddEquiv arising from
the Setoid quotient construction (not from definitional ZMod 16 alias).

Per Kirby-Taylor 1990 + Rokhlin 1952 (signature mod 16 invariant). -/
noncomputable def omega4PinPlusBordismEquivZMod16 :
    Omega4PinPlusBordism ‚âÉ+ ZMod 16 where
  toFun := omega4PinPlusBordismToZMod16
  invFun := omega4PinPlusBordismOfZMod16
  left_inv x := by
    induction x using Quotient.inductionOn with | _ M =>
    apply Quotient.sound
    show (16 : ‚Ñ§) ‚à£ (((M.signature : ZMod 16).val : ‚Ñ§) - M.signature)
    -- Show the difference cast to ZMod 16 is zero, hence 16 divides
    have h : ((((M.signature : ZMod 16).val : ‚Ñ§) - M.signature : ‚Ñ§) : ZMod 16) = 0 := by
      push_cast
      rw [ZMod.natCast_zmod_val]
      ring
    exact (ZMod.intCast_zmod_eq_zero_iff_dvd _ 16).mp h
  right_inv n := omega4PinPlusBordismOfZMod16_signature n
  map_add' := omega4PinPlusBordismToZMod16.map_add'

/-! ## ¬ß5. Witnesses: [RP‚Å¥] = 1 and [K3 lift] = 0 in Omega4PinPlusBordism -/

/-- **`pinPlusRP4_class`** ‚Äî the class of the abstract `[RP‚Å¥, Pin‚Å∫]`
