/-- The anomaly phase of the őĹ-th phase: `e^{2ŌÄiőĹ/16}`, the concrete 16th-root-of-unity
realization of the shared ‚Ą§‚āĀ‚āÜ (it lands in `őľ‚āĀ‚āÜ` by `anomalyPhase_pow_sixteen`). -/
noncomputable def anomalyPhase (őĹ : ‚Ą§) : ‚Ąā := Complex.exp (2 * (Real.pi : ‚Ąā) * Complex.I * őĹ / 16)

/-- **The values are genuinely 16th roots of unity**: `anomalyPhase őĹ ^ 16 = 1`. This makes the
`őľ‚āĀ‚āÜ` framing load-bearing (the codomain `‚Ąā` restricts to `őľ‚āĀ‚āÜ` on the image). Together with
`anomalyPhase_add` and `anomalyPhase_faithful` (16 distinct values), the image is exactly the
cyclic group `őľ‚āĀ‚āÜ` generated by `ő∂‚āĀ‚āÜ = anomalyPhase 1`. -/
theorem anomalyPhase_pow_sixteen (őĹ : ‚Ą§) : anomalyPhase őĹ ^ 16 = 1 := by
  unfold anomalyPhase
  rw [‚Üź Complex.exp_nat_mul]
  rw [show (16 : ‚Ąē) * (2 * (Real.pi : ‚Ąā) * Complex.I * őĹ / 16)
      = (őĹ : ‚Ąā) * (2 * (Real.pi : ‚Ąā) * Complex.I) from by push_cast; ring]
  exact Complex.exp_int_mul_two_pi_mul_I őĹ

/-- **Headline (the central-charge ‚Üí phase relation, Vafa form at label level).** The anomaly
phase equals `e^{2ŌÄi¬∑c‚āč(őĹ)/8}`, where `c‚āč(őĹ) = őĹ/2` is the Kitaev central charge
(`KitaevSixteenFold`). This is the explicit map from the central charge to the anomaly phase;
the `/8` (not `/16`) is the genuine content ‚ÄĒ it is falsified by any wrong central-charge slope. -/
theorem anomalyPhase_eq_central_charge_phase (őĹ : ‚Ą§) :
    anomalyPhase őĹ =
      Complex.exp (2 * (Real.pi : ‚Ąā) * Complex.I * ((Kitaev16.kitaevCentralCharge őĹ : ‚Ąö) : ‚Ąā) / 8) := by
  unfold anomalyPhase Kitaev16.kitaevCentralCharge
  congr 1
  push_cast
  ring

/-- `őĹ ‚Ü¶ e^{2ŌÄiőĹ/16}` is an additive‚Üímultiplicative homomorphism, so the 16 anomaly phases form
the cyclic group `őľ‚āĀ‚āÜ` generated by `ő∂‚āĀ‚āÜ = anomalyPhase 1`. -/
theorem anomalyPhase_add (őĹ őľ : ‚Ą§) : anomalyPhase (őĹ + őľ) = anomalyPhase őĹ * anomalyPhase őľ := by
  unfold anomalyPhase; rw [‚Üź Complex.exp_add]; congr 1; push_cast; ring

/-- **Faithfulness (roots-of-unity realization).** `anomalyPhase őĹ = anomalyPhase őľ ‚ÜĒ 16 ‚ą£ (őĹ‚ąíőľ)`:
the 16 anomaly phases are genuinely distinct (kernel `= 16‚Ą§`). This is the `őľ‚āĀ‚āÜ`-codomain form of
the Wave-1 central-charge faithfulness. -/
theorem anomalyPhase_faithful (őĹ őľ : ‚Ą§) :
    anomalyPhase őĹ = anomalyPhase őľ ‚ÜĒ (16 : ‚Ą§) ‚ą£ (őĹ - őľ) := by
  unfold anomalyPhase
  rw [Complex.exp_eq_exp_iff_exists_int]
  constructor
  ¬∑ rintro ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    have h : (őĹ : ‚Ąā) - őľ = 16 * n := by
      field_simp at hn
      linear_combination hn
    exact_mod_cast h
  ¬∑ rintro ‚ü®n, hn‚ü©
    refine ‚ü®n, ?_‚ü©
    have : (őĹ : ‚Ąā) = őľ + 16 * n := by exact_mod_cast (by linarith : (őĹ : ‚Ą§) = őľ + 16 * n)
    rw [this]; ring

/-- The Standard Model (16 Weyl fermions per generation) sits at the identity anomaly phase `1`:
`anomalyPhase 16 = 1` ‚ÄĒ the trivial element of `őľ‚āĀ‚āÜ`, consistent with anomaly-freedom. -/
theorem sm_anomalyPhase_trivial : anomalyPhase 16 = 1 := by
  unfold anomalyPhase
  rw [show (2 * (Real.pi : ‚Ąā) * Complex.I * (16 : ‚Ą§) / 16) = 2 * (Real.pi : ‚Ąā) * Complex.I from by
